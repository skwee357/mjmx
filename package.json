{
  "name": "@mjmx/core",
  "version": "1.2.0",
  "description": "Write mjml using JSX syntax",
  "keywords": [
    "email",
    "jsx",
    "mjml",
    "typescript"
  ],
  "homepage": "https://mjmx.dev",
  "bugs": {
    "url": "https://github.com/skwee357/mjmx/issues"
  },
  "license": "MIT",
  "author": "Dmitry Kudryavtsev <contact@kudmitry.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/skwee357/mjmx"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./jsx-runtime": {
      "import": {
        "types": "./dist/jsx-runtime.d.ts",
        "default": "./dist/jsx-runtime.js"
      },
      "require": {
        "types": "./dist/jsx-runtime.d.cts",
        "default": "./dist/jsx-runtime.cjs"
      }
    },
    "./jsx-dev-runtime": {
      "import": {
        "types": "./dist/jsx-dev-runtime.d.ts",
        "default": "./dist/jsx-dev-runtime.js"
      },
      "require": {
        "types": "./dist/jsx-dev-runtime.d.cts",
        "default": "./dist/jsx-dev-runtime.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {},
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/mjml": "^5.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.56.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "mjml": "^4.15.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
